msgstr "a környező fényt új élénkséggel és intenzitással tükrözi vissza"

#. LIGHTNING={add="it crackles with energy"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1855
msgctxt "sphere_flavor"
msgid "it crackles with energy"
msgstr "csordul az energiától"

#. LONGEVITY={add="it always seems to be looking far into the distance"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1856
msgctxt "sphere_flavor"
msgid "it always seems to be looking far into the distance"
msgstr "Úgy tűnik, mindig messze a távolba tekint"

#. LOVE={add="it stares longingly at those nearby"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1857
msgctxt "sphere_flavor"
msgid "it stares longingly at those nearby"
msgstr "vágyakozva bámulja a közelében lévőket"

#. LOYALTY={add="it never abandons its companions"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1858
msgctxt "sphere_flavor"
msgid "it never abandons its companions"
msgstr "soha nem hagyja cserben társait"

#. LUCK={add="it changes direction suddenly at times"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1859
msgctxt "sphere_flavor"
msgid "it changes direction suddenly at times"
msgstr "időnként hirtelen irányt vált"

#. LUST={add="it has an unnerving stare"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1860
msgctxt "sphere_flavor"
msgid "it has an unnerving stare"
msgstr "zavarba ejtő tekintete van"

#. MARRIAGE={add="it heckles those it meets that are not married"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1861
msgctxt "sphere_flavor"
msgid "it heckles those it meets that are not married"
msgstr "kigúnyolja azokat, akikkel találkozik, és akik nem házasok"

#. MERCY={add="it always seems like it is on the verge of crying"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1862
msgctxt "sphere_flavor"
msgid "it always seems like it is on the verge of crying"
msgstr "mindig úgy tűnik, mintha mindjárt sírni kezdene"

#. METALS={add="it appears to have sharp shimmering edges on many parts of its
#. body"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1863
msgctxt "sphere_flavor"
msgid "it appears to have sharp shimmering edges on many parts of its body"
msgstr "Úgy tűnik, testének számos részén éles, csillogó élek vannak"

#. MINERALS={add="it has an angular appearance"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1864
msgctxt "sphere_flavor"
msgid "it has an angular appearance"
msgstr "szögletes megjelenésű"

#. MISERY={add="it has a distinctly depressing moan"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1865
msgctxt "sphere_flavor"
msgid "it has a distinctly depressing moan"
msgstr "jellegzetesen lehangoló nyögés hallatszik belőle"

#. MIST={add="it is difficult to see clearly"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1866
msgctxt "sphere_flavor"
msgid "it is difficult to see clearly"
msgstr "nehéz tisztán látni"

#. MOON={add="it changes color with the phases of the moon"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1867
msgctxt "sphere_flavor"
msgid "it changes color with the phases of the moon"
msgstr "a holdfázisokkal együtt változik a színe"

#. MOUNTAINS={add="it is very solidly built"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1868
msgctxt "sphere_flavor"
msgid "it is very solidly built"
msgstr "nagyon szilárdan van megépítve"

#. MUCK={add="there is a foul reek about it"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1869
msgctxt "sphere_flavor"
msgid "there is a foul reek about it"
msgstr "valami bűzös szag lengi körül"

#. MURDER={add="it cannot abide anything that lives"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1870
msgctxt "sphere_flavor"
msgid "it cannot abide anything that lives"
msgstr "nem tűri el semmilyen élőlényt"

#. MUSIC={add="it sounds clear tones as its body moves in time"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1871
msgctxt "sphere_flavor"
msgid "it sounds clear tones as its body moves in time"
msgstr "tiszta hangokat ad ki, miközben teste az ütemhez igazodva mozog"

#. NATURE={add="it seems most at ease when it is outdoors"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1872
msgctxt "sphere_flavor"
msgid "it seems most at ease when it is outdoors"
msgstr "úgy tűnik, a szabadban érzi magát a legjobban"

#. NIGHT={add="it eerily reflects the light of the stars and moon"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1873
msgctxt "sphere_flavor"
