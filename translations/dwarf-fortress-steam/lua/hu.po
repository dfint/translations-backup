msgid "it cannot look directly at somebody that has broken an oath"
msgstr "nem nézhet közvetlenül arra, aki megszegte az esküjét"

#. OCEANS={add="it always raises a part of its body toward the moon"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1876
msgctxt "sphere_flavor"
msgid "it always raises a part of its body toward the moon"
msgstr "mindig a testének egy részét a Hold felé emeli"

#. ORDER={add="it moves very stiffly"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1877
msgctxt "sphere_flavor"
msgid "it moves very stiffly"
msgstr "nagyon mereven mozog"

#. PAINTING={add="its surface is always enlivened with a refreshing play of
#. color"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1878
msgctxt "sphere_flavor"
msgid "its surface is always enlivened with a refreshing play of color"
msgstr "felületét mindig frissítő színjáték teszi élénkebbé"

#. PEACE={add="it has an incredibly calm demeanor"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1879
msgctxt "sphere_flavor"
msgid "it has an incredibly calm demeanor"
msgstr "hihetetlenül nyugodt a viselkedése"

