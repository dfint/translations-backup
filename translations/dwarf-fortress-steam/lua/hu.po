#. SALT={add="it makes nearby water undrinkable"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1893
msgctxt "sphere_flavor"
msgid "it makes nearby water undrinkable"
msgstr "ezáltal a közeli víz ihatatlanná válik"

#. SCHOLARSHIP={add="it always seems to be deep in thought"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1894
msgctxt "sphere_flavor"
msgid "it always seems to be deep in thought"
msgstr "Úgy tűnik, mindig mély gondolatokba merül"

#. SEASONS={add="its form is ever-changing"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1895
msgctxt "sphere_flavor"
msgid "its form is ever-changing"
msgstr "formája folyamatosan változik"

#. SILENCE={add="it makes absolutely no sound"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1896
msgctxt "sphere_flavor"
msgid "it makes absolutely no sound"
msgstr "egyáltalán nem ad ki hangot"

#. SKY={add="it has a slowly shifting pattern on its surface"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1897
msgctxt "sphere_flavor"
msgid "it has a slowly shifting pattern on its surface"
msgstr "felületén lassan változó mintázat látható"

#. SONG={add="it sings beautiful songs endlessly"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1898
msgctxt "sphere_flavor"
msgid "it sings beautiful songs endlessly"
msgstr "vég nélkül gyönyörű dalokat énekel"

#. SPEECH={add="it pays attention carefully to anybody that is speaking"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1899
msgctxt "sphere_flavor"
msgid "it pays attention carefully to anybody that is speaking"
msgstr "figyelmesen hallgat mindenkit, aki beszél"

#. STARS={add="it appears to sparkle after night falls"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1900
msgctxt "sphere_flavor"
msgid "it appears to sparkle after night falls"
msgstr "úgy tűnik, sötétedés után csillog"

#. STORMS={add="its movement is the sound of wind and rain"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1901
msgctxt "sphere_flavor"
msgid "its movement is the sound of wind and rain"
msgstr "mozgása a szél és az eső hangja"

#. STRENGTH={add="it looks solidly built"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1902
msgctxt "sphere_flavor"
msgid "it looks solidly built"
msgstr "szilárdan megépítettnek tűnik"

#. SUICIDE={add="it mutters to itself about death"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1903
msgctxt "sphere_flavor"
msgid "it mutters to itself about death"
msgstr "magában motyog a halálról"

#. SUN={add="it is difficult to look at directly"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1904
msgctxt "sphere_flavor"
msgid "it is difficult to look at directly"
msgstr "nehéz közvetlenül ránézni"

#. THEFT={add="it always seems to have its attention on the most valuable
#. object in the area"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1905
msgctxt "sphere_flavor"
msgid ""
"it always seems to have its attention on the most valuable object in the "
"area"
msgstr "Úgy tűnik, mindig a környék legértékesebb tárgyára irányul a figyelme"

#. THRALLDOM={add="its movements sound like the rattling of chains"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1906
msgctxt "sphere_flavor"
msgid "its movements sound like the rattling of chains"
msgstr "mozgása olyan, mintha láncok csörgése lenne"

#. THUNDER={add="it is incredibly noisy"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1907
msgctxt "sphere_flavor"
msgid "it is incredibly noisy"
msgstr "hihetetlenül zajos"

#. TORTURE={add="it appears to be covered with sharp hooks and barbs"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1908
msgctxt "sphere_flavor"
msgid "it appears to be covered with sharp hooks and barbs"
msgstr "úgy tűnik, éles kampókkal és szálkákkal van borítva"

#. TRADE={add="it seems most content when a fair wind is blowing"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1909
msgctxt "sphere_flavor"
msgid "it seems most content when a fair wind is blowing"
msgstr "úgy tűnik, akkor a legboldogabb, amikor kedvező szél fúj"

#. TRAVELERS={add="it never stops moving completely"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1910
msgctxt "sphere_flavor"
msgid "it never stops moving completely"
msgstr "soha nem áll meg teljesen"

#. TREACHERY={add="it is unsettling to be around"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1911
msgctxt "sphere_flavor"
msgid "it is unsettling to be around"
msgstr "nyugtalanító érzés a közelében lenni"

#. TREES={add="it is top-heavy"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1912
msgctxt "sphere_flavor"
msgid "it is top-heavy"
msgstr "túlzottan elöl nehezedik"

#. TRICKERY={add="it has a tendency to laugh quietly to itself every so
#. often"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1913
msgctxt "sphere_flavor"
msgid "it has a tendency to laugh quietly to itself every so often"
msgstr "időnként hajlamos halkan magában nevetni"

#. TRUTH={add="it tenses up throughout its entire body whenever somebody tells
#. a falsehood in its presence"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1914
msgctxt "sphere_flavor"
msgid ""
"it tenses up throughout its entire body whenever somebody tells a falsehood "
"in its presence"
msgstr ""
"az egész teste megfeszül, valahányszor valaki hazugságot mond a jelenlétében"

#. TWILIGHT={add="it chitters briefly before sunrise and just after
#. nightfall"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1915
msgctxt "sphere_flavor"
msgid "it chitters briefly before sunrise and just after nightfall"
msgstr "napkelte előtt és sötétedés után rövid ideig csiripel"

#. VALOR={add="it always tries to embolden any fighting in its presence with
#. exhortations of bravery, even its foes"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1916
msgctxt "sphere_flavor"
msgid ""
"it always tries to embolden any fighting in its presence with exhortations "
"of bravery, even its foes"
msgstr ""
"mindig igyekszik bátorítani a jelenlétében zajló harcokat, bátorságra "
"buzdítva a résztvevőket, még ellenfeleit is"

#. VICTORY={add="it looks very proud of itself"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1917
msgctxt "sphere_flavor"
msgid "it looks very proud of itself"
msgstr "nagyon büszkének tűnik magára"

#. VOLCANOS={add="it seems to glow brightly from within"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1918
msgctxt "sphere_flavor"
msgid "it seems to glow brightly from within"
msgstr "úgy tűnik, mintha belülről ragyogna"

#. WAR={add="it bellows and cheers without pause"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1919
msgctxt "sphere_flavor"
msgid "it bellows and cheers without pause"
msgstr "szünet nélkül üvölt és éljenzik"

#. WATER={add="it seems to flow as it moves"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1920
msgctxt "sphere_flavor"
msgid "it seems to flow as it moves"
msgstr "úgy tűnik, mintha mozgás közben áramlana"

#. WEALTH={add="it always seems to be counting something"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1921
msgctxt "sphere_flavor"
msgid "it always seems to be counting something"
msgstr "Úgy tűnik, mindig valamit számol"

#. WEATHER={add="it changes appearance based on the clouds and precipitation
#. above"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1922
msgctxt "sphere_flavor"
msgid "it changes appearance based on the clouds and precipitation above"
msgstr "a felette lévő felhők és csapadék függvényében változik a megjelenése"

#. WIND={add="it is surrounded by an everpresent rush of wind"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1923
msgctxt "sphere_flavor"
msgid "it is surrounded by an everpresent rush of wind"
msgstr "folyamatos szélroham veszi körül"

#. WISDOM={add="it acts with unwavering calm"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1924
msgctxt "sphere_flavor"
msgid "it acts with unwavering calm"
msgstr "megingathatatlan nyugalommal cselekszik"

#. WRITING={add="it is covered with divine writing"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1925
