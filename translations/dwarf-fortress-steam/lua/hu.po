msgid "it always nods eagerly when somebody is speaking"
msgstr "mindig lelkesen bólint, amikor valaki beszél"

#. SACRIFICE={add="it inspires those around it to acts of great sacrifice"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1892
