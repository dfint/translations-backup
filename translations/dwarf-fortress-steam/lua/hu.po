msgid "it leaves water wherever it goes"
msgstr "bárhová is megy, vizet hagy maga után"

#. RAINBOWS={add="it is strikingly colored"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1885
msgctxt "sphere_flavor"
msgid "it is strikingly colored"
msgstr "színei igazán feltűnőek"

#. REBIRTH={add="it alternates from instant to instant between sluggishness
#. and
#. extreme vibrancy"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1886
