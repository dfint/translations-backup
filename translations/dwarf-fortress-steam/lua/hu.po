msgctxt "sphere_flavor"
msgid "it moves with a bouncing rhythm"
msgstr "ugráló ritmusban mozog"

#. REVENGE={add="it has a fixed and unblinking gaze when interacting"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1888
