#. JEWELS={add="its whole body appears to be faceted in a symmetric fashion"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1848
msgctxt "sphere_flavor"
msgid "its whole body appears to be faceted in a symmetric fashion"
msgstr ""
"dealraíonn sé go bhfuil a chorp iomlán ilghnéitheach ar bhealach siméadrach"

#. JUSTICE={add="it seems eager to pronounce judgment on others"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1849
msgctxt "sphere_flavor"
msgid "it seems eager to pronounce judgment on others"
msgstr ""
"dealraíonn sé go bhfuil fonn air breithiúnas a thabhairt ar dhaoine eile"

#. LABOR={add="it appears very deliberate in its actions"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1850
msgctxt "sphere_flavor"
msgid "it appears very deliberate in its actions"
msgstr "dealraíonn sé go bhfuil sé an-dian ina chuid gníomhartha"

#. LAKES={add="it moves ponderously"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1851
msgctxt "sphere_flavor"
msgid "it moves ponderously"
msgstr "gluaiseann sé go trom"

#. LAWS={add="it has a very stark look about it"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1852
msgctxt "sphere_flavor"
msgid "it has a very stark look about it"
msgstr "tá cuma an-gharbh air"

#. LIES={add="it seems unerringly honest if one does not concentrate"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1853
msgctxt "sphere_flavor"
msgid "it seems unerringly honest if one does not concentrate"
msgstr ""
"dealraíonn sé go bhfuil sé macánta go dosheachanta mura ndíríonn tú d'aire "
"air"

#. LIGHT={add="it returns surrounding light with a new vibrance and
#. intensity"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1854
msgctxt "sphere_flavor"
msgid "it returns surrounding light with a new vibrance and intensity"
msgstr "aisthiteann sé solas máguaird le brí agus déine nua"

#. LIGHTNING={add="it crackles with energy"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1855
msgctxt "sphere_flavor"
msgid "it crackles with energy"
msgstr "tá sé ag scoilteadh le fuinneamh"

#. LONGEVITY={add="it always seems to be looking far into the distance"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1856
msgctxt "sphere_flavor"
msgid "it always seems to be looking far into the distance"
msgstr "dealraíonn sé go bhfuil sé ag féachaint i bhfad i gcéin i gcónaí"

#. LOVE={add="it stares longingly at those nearby"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1857
msgctxt "sphere_flavor"
msgid "it stares longingly at those nearby"
msgstr "breathnaíonn sé go fada ar dhaoine in aice láimhe"

#. LOYALTY={add="it never abandons its companions"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1858
msgctxt "sphere_flavor"
msgid "it never abandons its companions"
msgstr "ní thréigeann sé a chompánaigh riamh"

#. LUCK={add="it changes direction suddenly at times"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1859
msgctxt "sphere_flavor"
msgid "it changes direction suddenly at times"
msgstr "athraíonn sé treo go tobann ó am go ham"

#. LUST={add="it has an unnerving stare"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1860
msgctxt "sphere_flavor"
msgid "it has an unnerving stare"
msgstr "tá amharc míshocair aige"

#. MARRIAGE={add="it heckles those it meets that are not married"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1861
msgctxt "sphere_flavor"
msgid "it heckles those it meets that are not married"
msgstr "magann sé faoi gach duine nach bhfuil pósta a mbuaileann sé leo"

#. MERCY={add="it always seems like it is on the verge of crying"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1862
msgctxt "sphere_flavor"
msgid "it always seems like it is on the verge of crying"
msgstr "dealraíonn sé i gcónaí go bhfuil sé ar tí caoineadh"

#. METALS={add="it appears to have sharp shimmering edges on many parts of its
#. body"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1863
msgctxt "sphere_flavor"
msgid "it appears to have sharp shimmering edges on many parts of its body"
msgstr ""
"dealraíonn sé go bhfuil faobhair ghéara ag taitneamh ar go leor codanna dá "
"chorp"

#. MINERALS={add="it has an angular appearance"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1864
msgctxt "sphere_flavor"
msgid "it has an angular appearance"
msgstr "tá cuma uilleach air"

#. MISERY={add="it has a distinctly depressing moan"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1865
msgctxt "sphere_flavor"
msgid "it has a distinctly depressing moan"
msgstr "tá osna fhíorbhrónach aige"

#. MIST={add="it is difficult to see clearly"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1866
msgctxt "sphere_flavor"
msgid "it is difficult to see clearly"
msgstr "tá sé deacair é a fheiceáil go soiléir"

#. MOON={add="it changes color with the phases of the moon"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1867
msgctxt "sphere_flavor"
msgid "it changes color with the phases of the moon"
msgstr "athraíonn sé dath de réir phasanna na gealaí"

#. MOUNTAINS={add="it is very solidly built"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1868
msgctxt "sphere_flavor"
msgid "it is very solidly built"
msgstr "tá sé tógtha go han-daingean"

#. MUCK={add="there is a foul reek about it"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1869
msgctxt "sphere_flavor"
msgid "there is a foul reek about it"
msgstr "tá drochbholadh bréan uaidh"

#. MURDER={add="it cannot abide anything that lives"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1870
msgctxt "sphere_flavor"
msgid "it cannot abide anything that lives"
msgstr "ní féidir leis cur suas le haon rud atá beo"

#. MUSIC={add="it sounds clear tones as its body moves in time"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1871
msgctxt "sphere_flavor"
msgid "it sounds clear tones as its body moves in time"
msgstr ""
"scaoileann sé fuaimeanna glana de réir mar a ghluaiseann a chorp in am"

#. NATURE={add="it seems most at ease when it is outdoors"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1872
msgctxt "sphere_flavor"
msgid "it seems most at ease when it is outdoors"
msgstr ""
"dealraíonn sé gurb amhlaidh is mó atá sé ar a shuaimhneas amuigh faoin aer"

#. NIGHT={add="it eerily reflects the light of the stars and moon"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1873
msgctxt "sphere_flavor"
msgid "it eerily reflects the light of the stars and moon"
msgstr "aisthiteann sé solas na n-réaltaí agus na gealaí go hiontach uafásach"

#. NIGHTMARES={add="it reminds those that look upon it of their most
#. unpleasant
#. memories"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1874
msgctxt "sphere_flavor"
msgid "it reminds those that look upon it of their most unpleasant memories"
msgstr ""
"cuireann sé i gcuimhne do dhaoine a fhéachann air na cuimhní cinn is measa "
"atá acu"

#. OATHS={add="it cannot look directly at somebody that has broken an oath"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1875
msgctxt "sphere_flavor"
msgid "it cannot look directly at somebody that has broken an oath"
msgstr "ní féidir leis breathnú go díreach ar dhuine a bhris mionn"

#. OCEANS={add="it always raises a part of its body toward the moon"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1876
msgctxt "sphere_flavor"
msgid "it always raises a part of its body toward the moon"
msgstr "tógann sé cuid dá chorp i dtreo na gealaí i gcónaí"

#. ORDER={add="it moves very stiffly"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1877
msgctxt "sphere_flavor"
msgid "it moves very stiffly"
msgstr "gluaiseann sé go han-stioftha"

#. PAINTING={add="its surface is always enlivened with a refreshing play of
#. color"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1878
msgctxt "sphere_flavor"
msgid "its surface is always enlivened with a refreshing play of color"
msgstr "tá a dhromchla beo i gcónaí le spraoi dathanna"

#. PEACE={add="it has an incredibly calm demeanor"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1879
msgctxt "sphere_flavor"
msgid "it has an incredibly calm demeanor"
msgstr "tá iompar thar a bheith socair aige"

#. PERSUASION={add="it rocks back and forth whenever somebody changes their
#. mind in its presence"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1880
msgctxt "sphere_flavor"
msgid ""
"it rocks back and forth whenever somebody changes their mind in its presence"
msgstr ""
"luascann sé anonn is anall gach uair a athraíonn duine éigin a intinn ina "
"láthair"

#. PLANTS={add="it always seems to point toward the sun when it is in the
#. sky"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1881
msgctxt "sphere_flavor"
msgid "it always seems to point toward the sun when it is in the sky"
msgstr ""
"dealraíonn sé i gcónaí go bpointeann sé i dtreo na gréine nuair atá sí sa "
"spéir"

#. POETRY={add="it recites verses in a strange language on occasion"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1882
msgctxt "sphere_flavor"
msgid "it recites verses in a strange language on occasion"
msgstr "aithrisíonn sé rann i dteanga strainséartha uaireanta"

#. PREGNANCY={add="it appears to be expecting"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1883
msgctxt "sphere_flavor"
msgid "it appears to be expecting"
msgstr "dealraíonn sé go bhfuil sé ag súil"

#. RAIN={add="it leaves water wherever it goes"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1884
msgctxt "sphere_flavor"
msgid "it leaves water wherever it goes"
msgstr "fágann sé uisce gach áit a dtéann sé"

#. RAINBOWS={add="it is strikingly colored"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1885
msgctxt "sphere_flavor"
msgid "it is strikingly colored"
msgstr "tá dath an-fheiceálach air"

#. REBIRTH={add="it alternates from instant to instant between sluggishness
#. and
#. extreme vibrancy"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1886
msgctxt "sphere_flavor"
msgid ""
"it alternates from instant to instant between sluggishness and extreme "
"vibrancy"
msgstr ""
"athraíonn sé ó nóiméad go nóiméad idir a bheith mall agus a bheith thar a "
"bheith bríomhar"

#. REVELRY={add="it moves with a bouncing rhythm"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1887
msgctxt "sphere_flavor"
msgid "it moves with a bouncing rhythm"
msgstr "gluaiseann sé le rithim phreabach"

#. REVENGE={add="it has a fixed and unblinking gaze when interacting"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1888
msgctxt "sphere_flavor"
msgid "it has a fixed and unblinking gaze when interacting"
msgstr "tá amharc seasta gan bhuailt na súl aige agus é ag gníomhú"

#. RIVERS={add="its outer surface seems to flow about its body"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1889
msgctxt "sphere_flavor"
msgid "its outer surface seems to flow about its body"
msgstr "dealraíonn sé go sreabhann a dhromchla seachtrach thart ar a chorp"

#. RULERSHIP={add="it is hard to disobey"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1890
msgctxt "sphere_flavor"
msgid "it is hard to disobey"
msgstr "tá sé deacair gan géilleadh dó"

#. RUMORS={add="it always nods eagerly when somebody is speaking"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1891
msgctxt "sphere_flavor"
msgid "it always nods eagerly when somebody is speaking"
msgstr ""
"clannann sé a cheann go fonnmhar i gcónaí nuair a bhíonn duine ag labhairt"

#. SACRIFICE={add="it inspires those around it to acts of great sacrifice"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1892
msgctxt "sphere_flavor"
msgid "it inspires those around it to acts of great sacrifice"
msgstr ""
"spreagann sé daoine thart air chun gníomhartha sár-íobairtí a dhéanamh"

#. SALT={add="it makes nearby water undrinkable"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1893
msgctxt "sphere_flavor"
msgid "it makes nearby water undrinkable"
msgstr "déanann sé uisce in aice láimhe do-ólta"

#. SCHOLARSHIP={add="it always seems to be deep in thought"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1894
msgctxt "sphere_flavor"
msgid "it always seems to be deep in thought"
msgstr "dealraíonn sé i gcónaí go bhfuil sé tumtha i smaointe"

#. SEASONS={add="its form is ever-changing"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1895
msgctxt "sphere_flavor"
msgid "its form is ever-changing"
msgstr "tá a fhoirm ag athrú de shíor"

#. SILENCE={add="it makes absolutely no sound"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1896
msgctxt "sphere_flavor"
msgid "it makes absolutely no sound"
msgstr "ní dhéanann sé fuaim ar bith"

#. SKY={add="it has a slowly shifting pattern on its surface"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1897
msgctxt "sphere_flavor"
msgid "it has a slowly shifting pattern on its surface"
msgstr "tá patrún ag athrú go mall ar a dhromchla"

#. SONG={add="it sings beautiful songs endlessly"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1898
msgctxt "sphere_flavor"
msgid "it sings beautiful songs endlessly"
msgstr "canaíonn sé amhráin áille gan stad"

#. SPEECH={add="it pays attention carefully to anybody that is speaking"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1899
msgctxt "sphere_flavor"
msgid "it pays attention carefully to anybody that is speaking"
msgstr "tugann sé aird ghéar ar dhuine ar bith atá ag labhairt"

#. STARS={add="it appears to sparkle after night falls"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1900
msgctxt "sphere_flavor"
msgid "it appears to sparkle after night falls"
msgstr "dealraíonn sé go bhfuil sé ag taitneamh tar éis titim na hoíche"

#. STORMS={add="its movement is the sound of wind and rain"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1901
msgctxt "sphere_flavor"
msgid "its movement is the sound of wind and rain"
msgstr "is é a ghluaiseacht fuaim na gaoithe agus na báistí"

#. STRENGTH={add="it looks solidly built"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1902
msgctxt "sphere_flavor"
msgid "it looks solidly built"
msgstr "tá cuma dhaingean air"

#. SUICIDE={add="it mutters to itself about death"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1903
msgctxt "sphere_flavor"
msgid "it mutters to itself about death"
msgstr "mutterálann sé leis féin faoin mbás"

#. SUN={add="it is difficult to look at directly"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1904
msgctxt "sphere_flavor"
msgid "it is difficult to look at directly"
msgstr "tá sé deacair breathnú go díreach air"

#. THEFT={add="it always seems to have its attention on the most valuable
#. object in the area"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1905
msgctxt "sphere_flavor"
msgid ""
"it always seems to have its attention on the most valuable object in the "
"area"
msgstr ""
"dealraíonn sé i gcónaí go bhfuil a aird ar an rud is luachmhaire sa cheantar"

#. THRALLDOM={add="its movements sound like the rattling of chains"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1906
msgctxt "sphere_flavor"
msgid "its movements sound like the rattling of chains"
msgstr "tá fuaim a ghluaiseachtaí cosúil le slabhraí ag bualadh"

#. THUNDER={add="it is incredibly noisy"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1907
msgctxt "sphere_flavor"
msgid "it is incredibly noisy"
msgstr "tá sé thar a bheith torannach"

#. TORTURE={add="it appears to be covered with sharp hooks and barbs"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1908
msgctxt "sphere_flavor"
msgid "it appears to be covered with sharp hooks and barbs"
msgstr "dealraíonn sé go bhfuil sé clúdaithe le crúcaí agus deilgne géara"

#. TRADE={add="it seems most content when a fair wind is blowing"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1909
msgctxt "sphere_flavor"
msgid "it seems most content when a fair wind is blowing"
msgstr ""
"dealraíonn sé gurb amhlaidh is mó atá sé sásta nuair a bhíonn gaoth bhreá ag"
" séideadh"

#. TRAVELERS={add="it never stops moving completely"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1910
msgctxt "sphere_flavor"
msgid "it never stops moving completely"
msgstr "ní stopann sé ag gluaiseacht go hiomlán riamh"

#. TREACHERY={add="it is unsettling to be around"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1911
msgctxt "sphere_flavor"
msgid "it is unsettling to be around"
msgstr "tá sé corraitheach a bheith thart air"

#. TREES={add="it is top-heavy"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1912
msgctxt "sphere_flavor"
msgid "it is top-heavy"
msgstr "tá sé trom ag an mbarr"

#. TRICKERY={add="it has a tendency to laugh quietly to itself every so
#. often"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1913
msgctxt "sphere_flavor"
msgid "it has a tendency to laugh quietly to itself every so often"
msgstr "bítear ag gáire go ciúin leis féin ó am go ham"

#. TRUTH={add="it tenses up throughout its entire body whenever somebody tells
#. a falsehood in its presence"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1914
msgctxt "sphere_flavor"
msgid ""
"it tenses up throughout its entire body whenever somebody tells a falsehood "
"in its presence"
msgstr ""
"cruann sé a chorp ar fad gach uair a insíonn duine éigin bréag ina láthair"

#. TWILIGHT={add="it chitters briefly before sunrise and just after
#. nightfall"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1915
msgctxt "sphere_flavor"
msgid "it chitters briefly before sunrise and just after nightfall"
msgstr ""
"cliceálann sé go gairid roimh éirí na gréine agus díreach tar éis titim na "
"hoíche"

#. VALOR={add="it always tries to embolden any fighting in its presence with
#. exhortations of bravery, even its foes"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1916
msgctxt "sphere_flavor"
msgid ""
"it always tries to embolden any fighting in its presence with exhortations "
"of bravery, even its foes"
msgstr ""
"déanann sé iarracht i gcónaí troid ina láthair a spreagadh le mian "
"crógachta, fiú a naimhde"

#. VICTORY={add="it looks very proud of itself"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1917
msgctxt "sphere_flavor"
msgid "it looks very proud of itself"
msgstr "tá cuma an-bhródúil air as féin"

#. VOLCANOS={add="it seems to glow brightly from within"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1918
msgctxt "sphere_flavor"
msgid "it seems to glow brightly from within"
msgstr ""

#. WAR={add="it bellows and cheers without pause"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1919
msgctxt "sphere_flavor"
msgid "it bellows and cheers without pause"
msgstr ""

#. WATER={add="it seems to flow as it moves"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1920
msgctxt "sphere_flavor"
msgid "it seems to flow as it moves"
msgstr ""

#. WEALTH={add="it always seems to be counting something"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1921
msgctxt "sphere_flavor"
msgid "it always seems to be counting something"
msgstr ""

#. WEATHER={add="it changes appearance based on the clouds and precipitation
#. above"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1922
msgctxt "sphere_flavor"
msgid "it changes appearance based on the clouds and precipitation above"
msgstr ""

#. WIND={add="it is surrounded by an everpresent rush of wind"}
#: data/vanilla/vanilla_procedural/scripts/generators/creatures.lua:1923
msgctxt "sphere_flavor"
msgid "it is surrounded by an everpresent rush of wind"
