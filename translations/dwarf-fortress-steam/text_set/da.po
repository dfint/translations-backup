"I have taken down [CONTEXT:NUMBER] [CONTEXT:RACE:NUMBERED_NAME] while "
"stalking [CONTEXT:PLACE:TRANS_NAME]."
msgstr ""
"Jeg har nedlagt [CONTEXT:NUMBER] [CONTEXT:RACE:NUMBERED_NAME] mens jeg "
"stalkede [CONTEXT:PLACE:TRANS_NAME]."

