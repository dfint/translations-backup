msgstr "Jeg er [SPEAKER:TRANS_NAME]. Hvordan kan jeg være til tjeneste?"

msgid "Hello, [AUDIENCE:RACE].  I am [SPEAKER:TRANS_NAME]."
msgstr "Hej, [AUDIENCE:RACE]. Jeg er [SPEAKER:TRANS_NAME]."

msgid "[AUDIENCE:FIRST_NAME]...  your parents must have been interesting!"
msgstr "[AUDIENCE:FIRST_NAME]... dine forældre må have været interessante!"

msgid ""
"You know, you don't meet many people with the name [AUDIENCE:FIRST_NAME]."
msgstr ""
"Du ved, man møder ikke mange personer med navnet [AUDIENCE:FIRST_NAME]."

msgid "So, [AUDIENCE:FIRST_NAME]...   [AUDIENCE:FIRST_NAME], was it?"
msgstr "Så, [AUDIENCE:FIRST_NAME]... var det [AUDIENCE:FIRST_NAME]?"

msgid "[AUDIENCE:FIRST_NAME].  Does that mean something?"
msgstr "[AUDIENCE:FIRST_NAME]. Betyder det noget?"

msgid "[AUDIENCE:FIRST_NAME].  I can't say I've heard that before."
msgstr "[AUDIENCE:FIRST_NAME]. Jeg kan ikke sige jeg har hørt det før."

msgid "Praise be to [SPEAKER:HF_LINK:DEITY:TRANS_NAME]."
msgstr "Lovet være [SPEAKER:HF_LINK:DEITY:TRANS_NAME]."

msgid "Praise [SPEAKER:HF_LINK:DEITY:RANDOM_DEF_SPHERE]."
msgstr "Lovpris [SPEAKER:HF_LINK:DEITY:RANDOM_DEF_SPHERE]."

msgid "Life is, in a word, [SPEAKER:HF_LINK:DEITY:RANDOM_DEF_SPHERE]."
msgstr "Livet er, i et ord, [SPEAKER:HF_LINK:DEITY:RANDOM_DEF_SPHERE]."

msgid "This servant of [SPEAKER:HF_LINK:DEITY:TRANS_NAME] greets you."
msgstr "Denne tjener af [SPEAKER:HF_LINK:DEITY:TRANS_NAME] hilser på dig."

msgid "This servant of [SPEAKER:HF_LINK:DEITY:RANDOM_DEF_SPHERE] greets you."
msgstr ""
"Denne tjener af [SPEAKER:HF_LINK:DEITY:RANDOM_DEF_SPHERE] hilser på dig."

msgid "I am a guard."
msgstr "Jeg er en vagt."

msgid "Don't start any trouble."
msgstr "Start ikke nogen problemer."

