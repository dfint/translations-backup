msgid "Look at you!"
msgstr "Se på dig!"

msgid "A baby!  How adorable!"
msgstr "En baby! Hvor bedårende!"

msgid "Ah, hello.  I'm [SPEAKER:TRANS_NAME]."
msgstr "Åh, hej. Jeg er [SPEAKER:TRANS_NAME]."

