msgid "who was too short to live"
msgstr "ki nem ért fel az élethez"

msgid "who tunneled away from me like a frightened mole"
msgstr "ki földikutya módjára elásta magát"

msgid "who sucked plump helmets like a purring maggot"
msgstr "aki úgy szopogatta a duzzadt sisakokat, mint egy doromboló féreg"

msgid "whose hammer shattered on the anvil of my power"
msgstr "akinek kalapácsa összetört az én hatalmam üllőjén"

msgid "who forged [PRO_POS] own doom by challenging me"
msgstr "aki azzal, hogy kihívott engem, saját vesztét okozta [PRO_POS]"

msgid "who was returned to the rock and muck from which it was spawned"
msgstr "akit visszavittek a sziklára és a sárba, ahonnan származott"

msgid ""
"whose tall tales of bravery were all the more embarrassing because of "
"[PRO_POS] height"
msgstr ""
"akinek a bátorságról szóló túlzott történetei [PRO_POS] magassága miatt még "
"kínosabbak voltak"

msgid "who was felled like a slender sapling"
msgstr "akit úgy vágtak ki, mint egy karcsú csemetét"

msgid "whom I sent back to the home-tree as fertilizer"
msgstr "akit visszaküldtem az anyafához, hogy trágyaként szolgáljon"

msgid "whose fragile bones shattered before the power of my contempt"
msgstr "akinek törékeny csontjai összetörtek a megvetésem ereje előtt"

msgid "who came down from the home-tree and was devoured"
msgstr "aki leereszkedett az otthoni fáról, és akit felfaltak"

msgid ""
"who should have stayed in the trees when the real elves came down to fight"
msgstr ""
"akiknek a fák között kellett volna maradniuk, amikor az igazi tündék "
"lejöttek harcolni"

msgid "I want your bones for my bone mill!"
msgstr "A csontjaidat akarom a csontőrlőmhöz!"

msgid "I'll grind you into porridge!"
msgstr "Pépesre verlek!"

msgid "I'll eat you whole!"
msgstr "Egyben lenyellek! "

msgid ""
"seek out [CONTEXT:HIST_FIG:TRANS_NAME] at "
"[CONTEXT:ABSTRACT_BUILDING:TRANS_NAME] over in [CONTEXT:SITE:TRANS_NAME]"
msgstr ""
"keresd [CONTEXT:HIST_FIG:TRANS_NAME] [CONTEXT:ABSTRACT_BUILDING:TRANS_NAME] "
"környékén, [CONTEXT:SITE:TRANS_NAME] felé"

msgid ""
"I have taken down [CONTEXT:NUMBER] [CONTEXT:RACE:NUMBERED_NAME] while "
"stalking [CONTEXT:PLACE:TRANS_NAME]."
msgstr ""
"Vadászatom során [CONTEXT:PLACE:TRANS_NAME] környékén megöltem "
"[CONTEXT:NUMBER] [CONTEXT:RACE:NUMBERED_NAME]t."

msgid ""
"It is said that the [CONTEXT:ARCH_ELEMENT] of "
"[CONTEXT:ABSTRACT_BUILDING:TRANS_NAME] [CONTEXT:JUSTIFICATION] "
"[CONTEXT:DEF_SPHERE] for the glory of [CONTEXT:HIST_FIG:TRANS_NAME]."
msgstr ""
"Azt mondják, hogy a [CONTEXT:ARCH_ELEMENT] a "
"[CONTEXT:ABSTRACT_BUILDING:TRANS_NAME] [CONTEXT:JUSTIFICATION] "
"[CONTEXT:DEF_SPHERE] [CONTEXT:HIST_FIG:TRANS_NAME] dicsőségére."

